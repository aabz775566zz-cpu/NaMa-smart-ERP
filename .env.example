# Root environment reference — copy per-app .env.example files for actual configuration

# Database (used by apps/api)
DATABASE_URL=postgresql://erp_smart:erp_smart_dev@localhost:5432/erp_smart?schema=public

# API
PORT=4000
JWT_SECRET=change-me-in-production
# Comma-separated allowed origins for the browser API/cookies. Optional —
# unset keeps the default localhost:3000/3001 dev origins.
# CORS_ORIGINS=https://app.example.com,https://staging.example.com

# Frontend URL — used to build links in transactional emails. Optional —
# unset keeps the default http://localhost:3000.
WEB_URL=http://localhost:3000

# Email (Resend). RESEND_API_KEY unset falls back to logging emails instead
# of sending them, so local dev works without an account.
RESEND_API_KEY=
EMAIL_FROM="ERP Smart <noreply@example.com>"

# Storage (Cloudinary) — later phases
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
