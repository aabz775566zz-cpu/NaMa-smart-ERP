// ERP Smart database schema
// Phase 2: Identity and Access Management (User, Company, Membership, Role,
// Permission, RefreshToken, ActivityLog).
// Phase 3: business modules (Products + Categories, Customers, Inventory,
// Sales, Invoices, Reports) — complete.
// Phase 4 (in progress): AI Intelligence Layer, one migration per pass. Part 1
// (AIConversation, AIMessage, AIUsageLog) below.
// Phase 7 (in progress): Purchase Management — Prisma layer only so far
// (Supplier, PurchaseInvoice, PurchaseInvoiceItem, SupplierPayment). API,
// services, permissions, and frontend land in a later pass.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum PlatformRole {
  USER
  SUPER_ADMIN
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

model User {
  id                     String       @id @default(cuid())
  email                  String       @unique
  passwordHash           String?
  fullName               String
  phone                  String?
  avatarUrl              String?
  isEmailVerified        Boolean      @default(false)
  emailVerifyToken       String?      @unique
  emailVerifyExpiresAt   DateTime?
  passwordResetToken     String?      @unique
  passwordResetExpiresAt DateTime?
  status                 UserStatus   @default(ACTIVE)
  platformRole           PlatformRole @default(USER)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  memberships             Membership[]
  refreshTokens           RefreshToken[]
  activityLogs            ActivityLog[]
  inventoryMovements      InventoryMovement[]
  sales                   Sale[]
  paymentsRecorded        Payment[]            @relation("PaymentsRecorded")
  purchaseInvoicesCreated PurchaseInvoice[]
  supplierPaymentsCreated SupplierPayment[]
  aiConversations         AIConversation[]
  aiUsageLogs             AIUsageLog[]

  @@index([passwordResetToken])
  @@index([emailVerifyToken])
}

model Company {
  id                 String   @id @default(cuid())
  name               String
  businessType       String?
  country            String?
  currency           String   @default("USD")
  logoUrl            String?
  subscriptionPlan   String   @default("FREE")
  subscriptionStatus String   @default("TRIALING")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  memberships        Membership[]
  roles              Role[]
  activityLogs       ActivityLog[]
  categories         Category[]
  products           Product[]
  customers          Customer[]
  inventoryMovements InventoryMovement[]
  sales              Sale[]
  invoices           Invoice[]
  payments           Payment[]
  suppliers          Supplier[]
  purchaseInvoices   PurchaseInvoice[]
  supplierPayments   SupplierPayment[]
  counters           CompanyCounter[]
  aiConversations    AIConversation[]
  aiMessages         AIMessage[]
  aiUsageLogs        AIUsageLog[]
}

model Membership {
  id        String           @id @default(cuid())
  userId    String
  companyId String
  roleId    String
  status    MembershipStatus @default(ACTIVE)
  invitedAt DateTime?
  joinedAt  DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id])

  @@unique([userId, companyId])
  @@index([companyId])
}

model Role {
  id        String   @id @default(cuid())
  companyId String? // null = system role template shared by all companies
  key       String // OWNER | MANAGER | ACCOUNTANT | EMPLOYEE | custom-slug
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  company     Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships Membership[]
  permissions RolePermission[]

  @@unique([companyId, key])
}

model Permission {
  id     String @id @default(cuid())
  module String
  action String

  roles RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  companyId String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

model Category {
  id        String   @id @default(cuid())
  companyId String
  name      String
  createdAt DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([companyId, name])
}

model Product {
  id                String        @id @default(cuid())
  companyId         String
  categoryId        String?
  name              String
  description       String?
  sku               String?
  imageUrl          String?
  purchasePrice     Decimal       @db.Decimal(14, 2)
  sellingPrice      Decimal       @db.Decimal(14, 2)
  quantityOnHand    Int           @default(0)
  // Free-text unit label (e.g. "kg", "box", "pcs"), not a Unit model with
  // conversions — a small-business catalog doesn't need multi-unit
  // conversion math today. Kept as a plain column specifically so a future
  // Unit table + unitId FK can be introduced additively later without a
  // breaking rework of this field.
  unit              String        @default("pcs")
  lowStockThreshold Int?
  status            ProductStatus @default(ACTIVE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  inventoryMovements   InventoryMovement[]
  saleItems            SaleItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]

  // Multiple products with sku = NULL are allowed (Postgres treats each NULL
  // as distinct in a unique index); this only enforces uniqueness once a sku
  // is actually set. Service-layer code additionally pre-checks availability
  // for a friendlier error than a raw constraint violation.
  @@unique([companyId, sku])
  @@index([companyId, status])
}

model Customer {
  id        String   @id @default(cuid())
  companyId String
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sales    Sale[]
  payments Payment[]

  @@index([companyId])
}

enum InventoryMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

model InventoryMovement {
  id              String                @id @default(cuid())
  companyId       String
  productId       String
  type            InventoryMovementType
  quantityChange  Int // signed: positive = stock in, negative = stock out
  referenceType   String? // e.g. "SALE" — loose pointer, not an FK; set by future modules
  referenceId     String?
  note            String?
  createdByUserId String // every movement is created by an authenticated action; no anonymous case exists (unlike ActivityLog)
  createdAt       DateTime              @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdBy User    @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([companyId, productId, createdAt])
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model Sale {
  id              String        @id @default(cuid())
  companyId       String
  customerId      String?
  createdByUserId String
  status          SaleStatus    @default(DRAFT)
  subtotal        Decimal       @db.Decimal(14, 2)
  discountTotal   Decimal       @db.Decimal(14, 2) @default(0)
  taxTotal        Decimal       @db.Decimal(14, 2) @default(0)
  totalAmount     Decimal       @db.Decimal(14, 2)
  paymentMethod   PaymentMethod @default(CASH)
  paymentStatus   PaymentStatus @default(UNPAID)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer?  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User       @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  items     SaleItem[]
  invoice   Invoice?

  @@index([companyId, status, createdAt])
}

model SaleItem {
  id        String  @id @default(cuid())
  companyId String // denormalized, same reason as everywhere else — uniform tenant-guard
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(14, 2) // snapshot of Product.sellingPrice at creation — never re-read later
  lineTotal Decimal @db.Decimal(14, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([companyId, saleId])
}

// Deliberately customer-level only — no saleId. Which sale(s) a payment
// covers is derived at read time by walking a customer's completed sales
// oldest-first against their payment total (see PaymentsService.computeLedger),
// never stored, so there is exactly one source of truth for "how much is
// owed": SUM(completed sale totals) - SUM(payments). Sale.paymentStatus and
// Invoice.status are kept as an accurate cache of that computation, written
// whenever a payment is recorded — never hand-toggled independently.
model Payment {
  id              String        @id @default(cuid())
  companyId       String
  customerId      String
  amount          Decimal       @db.Decimal(14, 2)
  method          PaymentMethod @default(CASH)
  note            String?
  createdByUserId String
  createdAt       DateTime      @default(now())

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User     @relation("PaymentsRecorded", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([companyId, customerId, createdAt])
}

enum InvoiceStatus {
  ISSUED
  PAID
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  saleId        String        @unique
  invoiceNumber String // formatted, e.g. "INV-0001"
  status        InvoiceStatus @default(ISSUED)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  totalAmount   Decimal       @db.Decimal(14, 2)
  createdAt     DateTime      @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Restrict)

  @@unique([companyId, invoiceNumber])
}

model CompanyCounter {
  companyId  String
  counterKey String // e.g. "INVOICE" — reusable for future document types
  value      Int    @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([companyId, counterKey])
}

model Supplier {
  id        String   @id @default(cuid())
  companyId String
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseInvoices PurchaseInvoice[]
  supplierPayments SupplierPayment[]

  @@index([companyId])
}

enum PurchaseInvoiceStatus {
  DRAFT
  RECEIVED
  CANCELLED
}

model PurchaseInvoice {
  id              String                @id @default(cuid())
  companyId       String
  supplierId      String
  invoiceNumber   String // the supplier's own bill number — free text, not auto-generated by us
  status          PurchaseInvoiceStatus @default(DRAFT)
  subtotal        Decimal               @db.Decimal(14, 2)
  discountTotal   Decimal               @db.Decimal(14, 2) @default(0)
  taxTotal        Decimal               @db.Decimal(14, 2) @default(0)
  totalAmount     Decimal               @db.Decimal(14, 2)
  issueDate       DateTime              @default(now())
  dueDate         DateTime?
  createdByUserId String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  company   Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier  Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy User                  @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  items     PurchaseInvoiceItem[]

  // No supplierPayments back-relation here — SupplierPayment is deliberately
  // supplier-level only (see its model comment), same reason Sale has no
  // `payments Payment[]` field today: which invoice(s) a payment covers is
  // derived at read time, never a stored FK.
  @@unique([companyId, invoiceNumber])
  @@index([companyId, status, createdAt])
}

model PurchaseInvoiceItem {
  id                String  @id @default(cuid())
  companyId         String // denormalized, same reason as everywhere else — uniform tenant-guard
  purchaseInvoiceId String
  productId         String
  quantity          Int
  unitCost          Decimal @db.Decimal(14, 2) // snapshot of cost at receipt — never re-read later
  lineTotal         Decimal @db.Decimal(14, 2)

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([companyId, purchaseInvoiceId])
}

// Deliberately supplier-level only — no purchaseInvoiceId. Which invoice(s) a
// payment covers is derived at read time by walking a supplier's received
// purchase invoices oldest-first against their payment total, mirroring
// Payment's customer-ledger design (see PaymentsService.computeLedger) —
// never stored, so there is exactly one source of truth for "how much we
// owe": SUM(received purchase invoice totals) - SUM(supplier payments).
model SupplierPayment {
  id              String        @id @default(cuid())
  companyId       String
  supplierId      String
  amount          Decimal       @db.Decimal(14, 2)
  method          PaymentMethod @default(CASH)
  note            String?
  createdByUserId String
  createdAt       DateTime      @default(now())

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier  Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy User     @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([companyId, supplierId, createdAt])
}

enum AIConversationVisibility {
  PRIVATE
  COMPANY
}

enum AIMessageRole {
  USER
  ASSISTANT
  TOOL
}

model AIConversation {
  id         String                   @id @default(cuid())
  companyId  String
  userId     String
  visibility AIConversationVisibility @default(PRIVATE)
  title      String?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AIMessage[]
  usageLogs AIUsageLog[]

  @@index([companyId, userId])
}

model AIMessage {
  id             String        @id @default(cuid())
  conversationId String
  companyId      String // denormalized, same reason as SaleItem.companyId
  role           AIMessageRole
  content        String
  sequence       Int           @default(autoincrement()) // absolute ordering guarantee, independent of timestamp resolution
  createdAt      DateTime      @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, conversationId, sequence])
}

enum AIUsageStatus {
  SUCCESS
  FAILURE
}

model AIUsageLog {
  id             String        @id @default(cuid())
  companyId      String
  userId         String
  conversationId String? // nullable + SetNull below: deleting a conversation must never fail or destroy usage/cost audit history
  model          String
  inputTokens    Int
  outputTokens   Int
  toolCalls      Json?
  status         AIUsageStatus @default(SUCCESS)
  durationMs     Int           @default(0) // AiService always sets this explicitly; default exists only to satisfy pre-existing rows on migration
  errorMessage   String?
  createdAt      DateTime      @default(now())

  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  conversation AIConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([userId])
}
