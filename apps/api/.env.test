# Test environment — used only by `npm test` (jest). Never used for real
# dev/prod traffic; contains no real secrets. The erp_smart_test database
# must exist before running tests (created once via `createdb`); the Jest
# globalSetup script applies migrations and re-seeds system roles
# automatically on every run (both idempotent, safe to repeat).
DATABASE_URL=postgresql://erp_smart:erp_smart_dev@localhost:5432/erp_smart_test?schema=public
PORT=4001
JWT_SECRET=test-only-secret-do-not-use-in-production
WEB_URL=http://localhost:3000
RESEND_API_KEY=
EMAIL_FROM="ERP Smart <test@example.com>"
